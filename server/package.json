{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate:test": "node scripts/run-with-test-db.js prisma migrate deploy",
    "db:seed:test": "node scripts/run-with-test-db.js tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.82",
    "@anthropic-ai/sdk": "^0.55.0",
    "@helpdesk/core": "*",
    "@prisma/client": "^6.0.0",
    "@sentry/node": "^10.58.0",
    "ai": "^6.0.205",
    "better-auth": "^1.6.16",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "pg-boss": "^12.19.1",
    "resend": "^4.0.0",
    "svix": "^1.95.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "prisma": "^6.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
